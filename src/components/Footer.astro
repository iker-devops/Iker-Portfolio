---
// ============================================================================
// Footer.astro
// ============================================================================
// Pie estilo "barra de estado" de OS antiguo — pegada abajo, biselada hacia
// adentro (parece hundida), con info a la izquierda y los iconos sociales
// a la derecha.
//
// PARA EDITAR LOS ENLACES: cambia las URLs del array `socials`.
// ============================================================================

// 👇 EDITA AQUÍ tus URLs de redes sociales 👇
const socials = [
  { name: 'GitHub',   url: 'https://github.com/iker-devops',                     icon: 'github' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/ikerreyesnavarro/',      icon: 'linkedin' },
  { name: 'Mail',     url: 'mailto:iker.reyesn8@gmail.com',                      icon: 'mail' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container-wide">
    <!-- IZQUIERDA: copyright en estilo "status bar" -->
    <div class="status-segment">
      <span class="status-dot" aria-hidden="true"></span>
      <span>{year} · La web de Iker</span>
    </div>

    <!-- CENTRO: pequeña info técnica -->
    <div class="status-segment status-center">
      <span>Hecho con Astro + CSS</span>
    </div>

    <!-- DERECHA: redes sociales como mini-botones biselados -->
    <ul class="socials">
      {socials.map((s) => (
        <li>
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.name}
            title={s.name}
            class="social-btn btn"
          >
            {s.icon === 'github' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            )}
            {s.icon === 'linkedin' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {s.icon === 'twitter' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {s.icon === 'mail' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="0"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    background: var(--window-chrome);
    /* Bisel HUNDIDO — la barra de estado parece presionada */
    box-shadow:
      inset 1px 1px 0 var(--bevel-dark),
      inset -1px -1px 0 var(--bevel-light),
      0 -1px 0 var(--bevel-edge);
    padding: 0.5rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Cada "segmento" de la barra de estado */
  .status-segment {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--fg-muted);
    font-family: var(--font-body);
    padding: 0.2rem 0.6rem;
    /* Bisel hundido sutil — cada segmento parece una "celdilla" */
    box-shadow:
      inset 1px 1px 0 var(--bevel-dark),
      inset -1px -1px 0 var(--bevel-light);
  }

  .status-center {
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  /* Punto verde de "estado: en línea" */
  .status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    box-shadow:
      inset 1px 1px 0 rgba(255, 255, 255, 0.4),
      0 0 0 1px var(--bevel-edge);
  }

  /* Lista de redes */
  .socials {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }

  .social-btn {
    /* Hereda los estilos de .btn (biselado) */
    width: 28px;
    height: 28px;
    padding: 0;
    color: var(--fg);
  }

  /* En móvil ocultamos el segmento central para ahorrar espacio */
  @media (max-width: 580px) {
    .status-center {
      display: none;
    }
  }
</style>
