---
// ============================================================================
// PostCard.astro
// ============================================================================
// Cada post se presenta como una FILA tipo "lista de archivos" del Finder/
// Explorer — con icono de documento, nombre, fecha y tamaño (usamos los
// tags como sustituto del "tamaño").
//
// El listado completo de cards va dentro de una <Window> en posts/index.astro
// para que parezca una ventana de explorador.
// ============================================================================

import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL;

// Fecha en español: "12 mar 2026"
const formattedDate = post.data.pubDate.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<a href={`${base}posts/${post.id}/`} class="file-row">
  <!-- Icono de documento a la izquierda -->
  <span class="file-icon" aria-hidden="true">
    <Icon name="document" size={16} />
  </span>

  <!-- Bloque de información: título + descripción + fecha + tags -->
  <div class="file-info">
    <h3 class="file-name">{post.data.title}.md</h3>
    <p class="file-desc">{post.data.description}</p>
  </div>

  <!-- Columnas de "metadatos" tipo Finder: fecha, tags -->
  <div class="file-meta">
    <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
    {post.data.tags.length > 0 && (
      <span class="file-tags">
        {post.data.tags.slice(0, 2).map((tag) => <span>#{tag}</span>)}
      </span>
    )}
  </div>
</a>

<style>
  /* Cada fila */
  .file-row {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.7rem 0.8rem;
    color: var(--fg);
    border-bottom: 1px dashed var(--border);
    transition: background 0.12s ease;
  }

  .file-row:last-child {
    border-bottom: none;
  }

  /* Hover: fondo verde sage (como una fila seleccionada en el Finder) */
  .file-row:hover {
    background: var(--accent);
    color: var(--titlebar-fg);
  }

  /* En hover, los textos secundarios se aclaran */
  .file-row:hover .file-name {
    color: var(--titlebar-fg);
  }

  .file-row:hover .file-desc,
  .file-row:hover .file-meta {
    color: var(--titlebar-fg);
    opacity: 0.9;
  }

  .file-row:hover .file-icon :global(svg) {
    color: white;
    fill: currentColor;
  }

  /* Icono */
  .file-icon {
    display: inline-flex;
    color: var(--icon);
  }

  :global([data-theme="dark"]) .file-icon {
    color: var(--icon);
  }

  /* Info (centro) */
  .file-info {
    min-width: 0;
  }

  .file-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 0.15rem 0;
    line-height: 1.2;
  }

  .file-desc {
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.45;
    margin: 0;
    /* Truncar a 2 líneas para mantener el grid limpio */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Metadatos a la derecha */
  .file-meta {
    text-align: right;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .file-tags {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.7rem;
  }

  .file-tags span {
    margin-left: 0.3rem;
  }

  /* En móvil ocultamos los metadatos y simplificamos */
  @media (max-width: 540px) {
    .file-row {
      grid-template-columns: 20px 1fr;
    }
    .file-meta {
      display: none;
    }
    .file-name {
      font-size: 0.95rem;
    }
  }
</style>
