---
// ============================================================================
// proyectos/index.astro — LISTADO DE PROYECTOS
// ============================================================================
// Todos los proyectos en una sola ventana titulada "proyectos/", con cada
// proyecto como una mini-ventana (ProjectCard) en un grid.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import Window from '../../components/Window.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('proyectos');
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.order !== b.data.order) return b.data.order - a.data.order;
  return b.data.year - a.data.year;
});
---

<BaseLayout
  title="Proyectos — Iker"
  description="Una selección de proyectos personales y trabajos en los que he participado."
>
  <div class="container">
    <header class="page-header">
      <span class="kicker">Proyectos</span>
      <h1>Cosas que he construido</h1>
      <p class="page-intro">
        Una selección de proyectos personales, herramientas internas y trabajos
        en los que he participado. Algunos siguen vivos, otros descansan en GitHub
        esperando volver.
      </p>
    </header>

    <Window title="proyectos/" icon="folder">
      <div class="toolbar">
        <span class="toolbar-info">
          {sortedProjects.length} {sortedProjects.length === 1 ? 'carpeta' : 'carpetas'}
        </span>
      </div>

      {sortedProjects.length === 0 ? (
        <p class="muted">Aún no hay proyectos publicados.</p>
      ) : (
        <div class="project-grid">
          {sortedProjects.map((proyecto) => <ProjectCard proyecto={proyecto} />)}
        </div>
      )}
    </Window>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin-bottom: 0.7rem;
  }

  .page-intro {
    color: var(--fg-muted);
    font-size: 1rem;
    max-width: 60ch;
  }

  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.8rem;
    margin: -1rem -1.2rem 1rem -1.2rem;
    background: var(--window-chrome);
    border-bottom: 1px solid var(--border);
    box-shadow: inset 1px 1px 0 var(--bevel-light), inset -1px -1px 0 var(--bevel-dark);
  }

  .toolbar-info {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-muted);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
  }
</style>
